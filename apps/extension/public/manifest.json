{
  "manifest_version": 3,
  "name": "nextslide",
  "version": "0.1.0",
  "description": "Control your Google Slides from any phone. No OAuth, no stored data.",
  "permissions": [
    "tabs",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://docs.google.com/presentation/*",
    "http://localhost:4545/*",
    "ws://localhost:4545/*",
    "https://nextslide.app/*",
    "wss://nextslide.app/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://docs.google.com/presentation/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "nextslide"
  }
}
